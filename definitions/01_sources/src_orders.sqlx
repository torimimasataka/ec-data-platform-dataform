config {
  type: "view",
  schema: "01_import",
  name: "src_orders",
  description: "注文ヘッダーのソースview"
}

SELECT
    order_id,
    customer_id,
    order_status,
    order_purchase_timestamp,
    order_approved_at,
    order_delivered_carrier_date,
    order_delivered_customer_date,
    order_estimated_delivery_date
FROM ${ref("orders")}
