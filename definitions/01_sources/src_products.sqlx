config {
  type: "view",
  schema: "01_import",
  name: "src_products",
  description: "商品マスタのソースview"
}

SELECT
    product_id,
    product_category_name,
    product_name_lenght,
    product_description_lenght,
    product_photos_qty,
    product_weight_g,
    product_length_cm,
    product_height_cm,
    product_width_cm
FROM ${ref("products")}
