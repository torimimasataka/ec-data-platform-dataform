config {
  type: "view",
  schema: "01_import",
  name: "src_order_reviews",
  description: "注文レビューのソースview"
}

SELECT
    review_id,
    order_id,
    review_score,
    review_comment_title,
    review_comment_message,
    review_creation_date,
    review_answer_timestamp
FROM ${ref("order_reviews")}
